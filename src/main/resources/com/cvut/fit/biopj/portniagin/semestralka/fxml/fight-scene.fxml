<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="fightBorderPane" prefHeight="700.0" prefWidth="1100.0" style="-fx-background-color: #1a0b04;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cvut.fit.biopj.portniagin.semestralka.controllers.FightController">
   <stylesheets>
      <URL value="@styles.css" />
   </stylesheets>

   <!-- Left: player panel -->
   <left>
      <VBox fx:id="playerDummyVBox" prefHeight="700.0" prefWidth="300.0" style="-fx-background-color: #2a1505; -fx-border-color: #6b3a15; -fx-border-width: 0 3 0 0;" BorderPane.alignment="CENTER" />
   </left>

   <!-- Center: session state + start/back buttons -->
   <center>
      <VBox alignment="TOP_CENTER" spacing="16.0" BorderPane.alignment="CENTER">
         <padding><Insets left="10.0" right="10.0" top="20.0" /></padding>
         <children>
            <HBox fx:id="sessionStateVBox" alignment="CENTER" prefHeight="80.0" prefWidth="200.0">
               <children>
                  <Button fx:id="forfeitButton" mnemonicParsing="false" onAction="#onForfeitButtonClick" prefHeight="40.0" prefWidth="60.0" style="-fx-background-color: linear-gradient(to bottom,#8b2020,#5a0d0d); -fx-border-color:#c84040 #902020 #902020 #c84040;" text="FF" textAlignment="CENTER" />
               </children>
            </HBox>

            <Button fx:id="startOfCombatButton" mnemonicParsing="false" onAction="#onStartOfCombatButtonClicked" prefHeight="54.0" prefWidth="160.0" text="START" wrapText="true">
               <font><Font name="Georgia Bold" size="22.0" /></font>
               <style>-fx-background-color: linear-gradient(to bottom,#1a6b20,#0d4010); -fx-border-color:#40c840 #208020 #208020 #40c840;</style>
            </Button>

            <Button fx:id="backToShopButton" disable="true" mnemonicParsing="false" onAction="#onBackToShopButtonClicked" prefHeight="50.0" prefWidth="160.0" text="TO SHOP" visible="false" wrapText="true">
               <font><Font name="Georgia Bold" size="18.0" /></font>
            </Button>
            <Button fx:id="toMenuButton" disable="true" mnemonicParsing="false" onAction="#onToMenuButtonClicked" prefHeight="54.0" prefWidth="160.0" style="-fx-background-color: linear-gradient(to bottom,#1a6b20,#0d4010); -fx-border-color:#40c840 #208020 #208020 #40c840;" text="MENU" visible="false" wrapText="true">
               <font>
                  <Font name="Georgia Bold" size="22.0" />
               </font>
            </Button>
         </children>
      </VBox>
   </center>

   <!-- Right: enemy panel -->
   <right>
      <VBox fx:id="enemyDummyVBox" prefHeight="700.0" prefWidth="300.0" style="-fx-background-color: #2a1505; -fx-border-color: #6b3a15; -fx-border-width: 0 0 0 3;" BorderPane.alignment="CENTER" />
   </right>
</BorderPane>
