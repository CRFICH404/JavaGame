<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="500.0"
      style="-fx-background-color: #1a0b04;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cvut.fit.biopj.portniagin.semestralka.controllers.LogInController">
   <stylesheets>
      <URL value="@styles.css" />
   </stylesheets>
   <children>
      <!-- Title -->
      <Label text="TOWER OF GOD" textAlignment="CENTER">
         <font><Font name="Georgia Bold" size="32.0" /></font>
         <style>-fx-text-fill: #c8942a; -fx-effect: dropshadow(gaussian, rgba(200,148,42,0.6), 10, 0.3, 0, 0);</style>
         <VBox.margin><Insets bottom="40.0" /></VBox.margin>
      </Label>

      <VBox alignment="CENTER"
            style="-fx-background-color: #2a1505; -fx-border-color: #6b3a15; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8;"
            maxWidth="340.0">
         <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
         <children>
            <TextField fx:id="userIDTextField" alignment="CENTER" prefHeight="38.0" prefWidth="280.0" promptText="username">
               <font><Font size="14.0" /></font>
               <VBox.margin><Insets bottom="14.0" /></VBox.margin>
            </TextField>

            <PasswordField fx:id="passwordTextField" alignment="CENTER" prefHeight="38.0" prefWidth="280.0" promptText="password">
               <font><Font size="14.0" /></font>
               <VBox.margin><Insets bottom="24.0" /></VBox.margin>
            </PasswordField>

            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button fx:id="buttonLogIn" mnemonicParsing="false" onAction="#onLoginButtonClick"
                          prefHeight="38.0" prefWidth="120.0" text="Log In" />
                  <Button fx:id="buttonRegister" mnemonicParsing="false" onAction="#onRegisterButtonClick"
                          prefHeight="38.0" prefWidth="120.0" text="Register" />
               </children>
            </HBox>
         </children>
      </VBox>

      <Label fx:id="buttonClickReactionTextLabel" textAlignment="CENTER"
             style="-fx-text-fill: #e06040;">
         <VBox.margin><Insets top="20.0" /></VBox.margin>
      </Label>
   </children>
   <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
</VBox>
