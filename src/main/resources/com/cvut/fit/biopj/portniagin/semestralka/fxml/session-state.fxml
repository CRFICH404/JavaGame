<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<HBox alignment="CENTER" spacing="6.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cvut.fit.biopj.portniagin.semestralka.controllers.SessionStateController">
   <padding><Insets bottom="6.0" left="10.0" right="10.0" top="6.0" /></padding>
   <children>
      <ImageView fx:id="dayImageView" fitHeight="44.0" fitWidth="44.0" pickOnBounds="true" preserveRatio="true">
         <image><Image url="@../grafics/moon-and-sun.png" /></image>
      </ImageView>
      <Label fx:id="dayCounter" text="1" style="-fx-text-fill: #f0d898;">
         <font><Font name="Georgia Bold" size="18.0" /></font>
         <HBox.margin><Insets right="12.0" /></HBox.margin>
      </Label>

      <ImageView fx:id="trophyImageView" fitHeight="44.0" fitWidth="44.0" pickOnBounds="true" preserveRatio="true">
         <image><Image url="@../grafics/trophy.png" /></image>
      </ImageView>
      <Label fx:id="winCounter" text="0/10" style="-fx-text-fill: #f0d898;">
         <font><Font name="Georgia Bold" size="18.0" /></font>
         <HBox.margin><Insets right="12.0" /></HBox.margin>
      </Label>

      <ImageView fx:id="playerHealthImageView" fitHeight="44.0" fitWidth="44.0" pickOnBounds="true" preserveRatio="true">
         <image><Image url="@../grafics/heart.png" /></image>
      </ImageView>
      <Label fx:id="playerHealthCounter" text="10/10" style="-fx-text-fill: #f0d898;">
         <font><Font name="Georgia Bold" size="18.0" /></font>
      </Label>
   </children>
</HBox>
