<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="900.0"
      style="-fx-background-color: #1a0b04;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cvut.fit.biopj.portniagin.semestralka.controllers.SettingsController">
   <stylesheets>
      <URL value="@styles.css" />
   </stylesheets>
   <children>
      <Label text="SETTINGS" textAlignment="CENTER" style="-fx-text-fill: #c8942a;">
         <font><Font name="Georgia Bold" size="30.0" /></font>
         <VBox.margin><Insets bottom="50.0" /></VBox.margin>
      </Label>

      <HBox alignment="CENTER">
         <children>
            <VBox alignment="CENTER" spacing="12.0" prefWidth="200.0">
               <children>
                  <Button prefHeight="38.0" prefWidth="160.0" text="Setting" mnemonicParsing="false" />
                  <Button prefHeight="38.0" prefWidth="160.0" text="Setting" mnemonicParsing="false" />
                  <Button prefHeight="38.0" prefWidth="160.0" text="Setting" mnemonicParsing="false" />
                  <Button prefHeight="38.0" prefWidth="160.0" text="Setting" mnemonicParsing="false" />
               </children>
            </VBox>
         </children>
      </HBox>

      <HBox alignment="BOTTOM_RIGHT" VBox.vgrow="ALWAYS">
         <VBox.margin><Insets top="60.0" right="40.0" bottom="30.0" /></VBox.margin>
         <children>
            <Button fx:id="backButton" mnemonicParsing="false" onAction="#onBackButtonClick"
                    prefHeight="38.0" prefWidth="100.0" text="Back" />
         </children>
      </HBox>
   </children>
</VBox>
