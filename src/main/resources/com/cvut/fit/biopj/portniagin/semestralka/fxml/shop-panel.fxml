<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cvut.fit.biopj.portniagin.semestralka.controllers.ShopController"
      style="-fx-background-color: #1a0b04;">
   <children>
      <!-- Top bar: session state + fight button -->
      <HBox alignment="CENTER" prefHeight="80.0"
            style="-fx-background-color: #2a1505; -fx-border-color: #6b3a15; -fx-border-width: 0 0 2 0;">
         <children>
            <HBox fx:id="sessionStateHBox" HBox.hgrow="ALWAYS">
               <padding><Insets left="20.0" /></padding>
            </HBox>
            <Button fx:id="fightButton" mnemonicParsing="false" onAction="#onFightButtonClick"
                    text="Fight!" prefHeight="44.0" prefWidth="120.0">
               <font><Font name="Georgia Bold" size="18.0" /></font>
               <HBox.margin><Insets right="24.0" /></HBox.margin>
               <style>-fx-background-color: linear-gradient(to bottom,#1a6b20,#0d4010); -fx-border-color:#40c840 #208020 #208020 #40c840;</style>
            </Button>
         </children>
      </HBox>

      <!-- Shop grid -->
      <HBox alignment="CENTER" VBox.vgrow="ALWAYS">
         <children>
            <GridPane fx:id="itemShopGridPane" alignment="CENTER" gridLinesVisible="true"
                      prefHeight="420.0" prefWidth="840.0">
               <columnConstraints>
                  <ColumnConstraints hgrow="ALWAYS" minWidth="150.0" prefWidth="200.0" />
                  <ColumnConstraints hgrow="ALWAYS" minWidth="150.0" prefWidth="200.0" />
                  <ColumnConstraints hgrow="ALWAYS" minWidth="150.0" prefWidth="200.0" />
                  <ColumnConstraints hgrow="ALWAYS" minWidth="150.0" prefWidth="200.0" />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints minHeight="180.0" prefHeight="200.0" vgrow="ALWAYS" />
                  <RowConstraints minHeight="180.0" prefHeight="200.0" vgrow="ALWAYS" />
               </rowConstraints>
               <padding><Insets bottom="0.0" left="0.0" right="0.0" top="0.0" /></padding>
            </GridPane>
         </children>
         <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
      </HBox>

      <!-- Bottom bar: reroll / freeze / level up -->
      <HBox alignment="CENTER_RIGHT"
            style="-fx-background-color: #2a1505; -fx-border-color: #6b3a15; -fx-border-width: 2 0 0 0;">
         <padding><Insets bottom="12.0" left="12.0" right="24.0" top="12.0" /></padding>
         <children>
            <Button fx:id="rerollButton" mnemonicParsing="false" onAction="#onRerollButtonClick"
                    text="Reroll" prefHeight="38.0" prefWidth="90.0">
               <HBox.margin><Insets right="10.0" /></HBox.margin>
            </Button>
            <Button fx:id="freezeButton" mnemonicParsing="false" onAction="#onFreezeButtonClick"
                    text="Freeze" prefHeight="38.0" prefWidth="90.0">
               <HBox.margin><Insets right="10.0" /></HBox.margin>
            </Button>
            <Button fx:id="levelUpButton" mnemonicParsing="false" onAction="#onLevelUpButtonClick"
                    text="Level Up" prefHeight="38.0" prefWidth="100.0" />
         </children>
      </HBox>
   </children>
</VBox>
